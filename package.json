{
  "name": "claude-code-dashboard",
  "version": "1.0.2",
  "description": "A local desktop dashboard for your Claude Code configuration",
  "author": "Terrence Fradet",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "demo": "DEMO=1 electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && dotenv -e .env -- electron-builder --mac --x64 --arm64",
    "package:dmg": "npm run build && dotenv -e .env -- electron-builder --mac dmg --universal",
    "package:mas": "npm run build && electron-builder --mac mas"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "gray-matter": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0"
  }
}
